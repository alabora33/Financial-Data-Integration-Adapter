# PostgreSQL
POSTGRES_DB=teamsec
POSTGRES_USER=teamsec
POSTGRES_PASSWORD=teamsec_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django (adapter/)
DJANGO_SECRET_KEY=change-me-use-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,adapter

# Harici Banka
BANK_BASE_URL=http://external_bank:8001

# Adapter (api/ → adapter/ iletişimi)
ADAPTER_BASE_URL=http://adapter:8002

# Dahili API güvenliği — api/ ↔ adapter/ arasında paylaşılan token
INTERNAL_API_TOKEN=change-me-strong-internal-token-in-production

# Periyodik sync (dakika; 0 = devre dışı)
SYNC_INTERVAL_MINUTES=60
SYNC_TENANTS=BANK001,BANK002,BANK003
SYNC_LOAN_TYPES=RETAIL,COMMERCIAL

# JWT (api/)
JWT_SECRET_KEY=change-me-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API Key auth (X-API-Key header) — key:role veya key:role:TENANT1|TENANT2
# Örnek: bank001-key:reader:BANK001 — yalnızca BANK001'e erişim
API_KEYS=teamsec-dev-key:admin,teamsec-readonly-key:readonly,bank001-key:reader:BANK001
